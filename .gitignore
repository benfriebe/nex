# Xcode
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
xcuserdata/
# xcodegen regenerates schemes from project.yml
*.xcodeproj/xcshareddata/

# macOS
.DS_Store
*.swp
*~

# libghostty (build from ghostty submodule, too large for git)
lib/libghostty.a

# Ghostty submodule build artifacts
ghostty/zig-out/
ghostty/zig-cache/
ghostty/.zig-cache/

# SPM
.build/
Packages/
Package.resolved

# Claude
.claude/

# Python
__pycache__/

# Local working docs (plans, notes — not part of the public repo).
# docs/* ignores the working notes but re-includes the public README
# screenshots (git can only re-include a subdir when the parent dir
# itself isn't excluded, hence docs/* rather than docs/).
docs/*
!docs/screenshots/
.nex-tasks/
.nex-results/
